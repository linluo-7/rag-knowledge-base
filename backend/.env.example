# RAG 知识库系统配置示例
# 复制此文件到 .env 并填写实际值

# ===== 环境配置 =====
ENV=development
DEBUG=false

# ===== API 配置 =====
API_HOST=0.0.0.0
API_PORT=5003
API_V1_PREFIX=/api/v1

# ===== 认证配置 =====
# API Key 列表，逗号分隔
API_KEYS=
AUTH_REQUIRED=false

# ===== 限流配置 =====
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ===== MiniMax LLM 配置 =====
MINIMAX_API_KEY=your_api_key_here
# 多个 API Key 用于轮换
MINIMAX_API_KEYS=
MINIMAX_BASE_URL=https://api.minimax.chat/v
LLM_MODEL=abab6.5s-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=120
LLM_RETRY_TIMES=3

# ===== Neo4j 配置 =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123456
NEO4J_DATABASE=neo4j
NEO4J_POOL_SIZE=10
NEO4J_CONNECTION_TIMEOUT=30

# ===== Milvus 配置 =====
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_COLLECTION=documents
MILVUS_DIM=768
MILVUS_POOL_SIZE=10
MILVUS_TIMEOUT=30

# ===== Embedding 配置 =====
EMBEDDING_MODEL=shibing624/text2vec-base-chinese
EMBEDDING_DEVICE=cpu
EMBEDDING_POOL_SIZE=5

# ===== 文本分块配置 =====
CHUNK_SIZE=256
CHUNK_OVERLAP=64

# ===== RRF 融合配置 =====
RRF_K=60
TOP_K=5
MAX_CONTEXT_K=3

# ===== Redis 缓存配置 =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=3600
CACHE_ENABLED=false

# ===== 上传配置 =====
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=[".txt", ".docx"]

# ===== 日志配置 =====
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=100
LOG_BACKUP_COUNT=10

# ===== 监控配置 =====
METRICS_ENABLED=true
TRACE_ENABLED=false